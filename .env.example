# =============================================================
# Amazon SP-API MCP Server — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual credentials.
# Get these values from your AWS Secrets Manager.
#
# This server supports multi-region (EU + NA) with separate
# refresh tokens per region.
# =============================================================

# --- AWS IAM Credentials (for Signature V4 signing) ---
# These are your IAM user credentials, NOT your root account.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# --- LWA (Login with Amazon) OAuth Credentials ---
# Shared across all regions. From your SP-API app registration.
LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxx
LWA_CLIENT_SECRET=your_lwa_client_secret_here

# --- Region-Specific Refresh Tokens ---
# EU token: covers Germany, France, Italy, Spain, Netherlands,
#           Belgium, Sweden, Poland, UK
# NA token: covers USA
#
# At least one is required. Both are needed for full coverage.
LWA_REFRESH_TOKEN_EU=Atzr|your_eu_refresh_token_here
LWA_REFRESH_TOKEN_NA=Atzr|your_na_refresh_token_here

# --- Seller Information ---
SELLER_ID=your_seller_id_here

# --- Optional: Logging ---
# LOG_LEVEL=info
